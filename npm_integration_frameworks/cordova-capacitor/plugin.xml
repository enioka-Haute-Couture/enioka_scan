<?xml version="1.0" encoding="utf-8"?>
<plugin xmlns="http://apache.org/cordova/ns/plugins/1.0"
        id="@enioka/cordova-plugin-enioka-scan"
        version="1.0.0">

  <name>EniokaScanPlugin</name>
  <description>enioka Scan integration plugin for Cordova and Capacitor</description>
  <license>Apache-2.0</license>
  <keywords>enioka,enioka-scan,android,barcode,qrcode,scanner,integration-layer,plugin,cordova,capacitor</keywords>

  <engines>
    <engine name="cordova-android" version=">=12.0.0"/>
  </engines>

  <js-module src="www/EniokaScanPlugin.js" name="EniokaScanPlugin">
    <clobbers target="EniokaScanPlugin"/>
  </js-module>

  <platform name="android">
    <config-file target="res/xml/config.xml" parent="/*">
      <feature name="EniokaScanPlugin">
        <param name="android-package" value="com.enioka.scanner.integration.EniokaScanPlugin" />
      </feature>
    </config-file>
    <config-file target="AndroidManifest.xml" parent="/*" />
    <source-file src="src/android/EniokaScanPlugin.java" target-dir="src/com/enioka/scanner/integration/" />
  </platform>
</plugin>