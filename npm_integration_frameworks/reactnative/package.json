{
  "name": "@enioka/react-native-plugin-enioka-scan",
  "version": "1.0.0",
  "description": "enioka Scan integration plugin for React Native",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "prepare": "bob build"
  },
  "keywords": [
    "enioka",
    "enioka-scan",
    "android",
    "barcode",
    "qrcode",
    "scanner",
    "integration-layer",
    "plugin",
    "ecosystem:react-native",
    "react-native",
    "react-native-android"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/enioka-Haute-Couture/enioka_scan"
  },
  "author": "enioka",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/enioka-Haute-Couture/enioka_scan/issues"
  },
  "homepage": "https://enioka-scan.readthedocs.io/en/latest/",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@react-native/babel-preset": "0.85.0",
    "@types/react": "^19.2.0",
    "react": "19.2.3",
    "react-native": "0.85.0",
    "react-native-builder-bob": "^0.41.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "EniokaScanModuleSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.enioka.scanner.integration"
    }
  },
  "create-react-native-library": {
    "type": "module-legacy",
    "languages": "kotlin-objc",
    "version": "0.62.0"
  }
}
